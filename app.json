{
  "name": "Code-T MD Pairing",
  "description": "WhatsApp MD bot with pairing system by Toputech",
  "logo": "https://telegra.ph/file/8dace2d24b82568c29e19.jpg",
  "repository": "https://github.com/Toputech5/Code-T",
  "keywords": ["whatsapp", "bot", "baileys", "md"],
  "success_url": "/",
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    }
  ],
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "env": {
    "PORT": {
      "description": "Port for the web server",
      "value": "5000"
    },
    "BOT_NAME": {
      "description": "Your bot name",
      "value": "CODE-T MD",
      "required": false
    }
  }
}
